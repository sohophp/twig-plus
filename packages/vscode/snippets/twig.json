{
  "Twig apply": {
    "prefix": "twig-apply",
    "body": [
      "{% apply ${1:filter} %}",
      "  $0",
      "{% endapply %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig autoescape": {
    "prefix": "twig-autoescape",
    "body": [
      "{% autoescape ${1:'html'} %}",
      "  $0",
      "{% endautoescape %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig block": {
    "prefix": "twig-block",
    "body": [
      "{% block ${1:name} %}",
      "  $0",
      "{% endblock %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig cache": {
    "prefix": "twig-cache",
    "body": [
      "{% cache ${1:key} %}",
      "  $0",
      "{% endcache %}"
    ],
    "description": "twig-extra Twig block tag"
  },
  "Twig embed": {
    "prefix": "twig-embed",
    "body": [
      "{% embed '${1:template.html.twig}' %}",
      "  $0",
      "{% endembed %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig for": {
    "prefix": "twig-for",
    "body": [
      "{% for ${1:item} in ${2:items} %}",
      "  $0",
      "{% endfor %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig guard": {
    "prefix": "twig-guard",
    "body": [
      "{% guard ${1:function} %}",
      "  $0",
      "{% endguard %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig if": {
    "prefix": "twig-if",
    "body": [
      "{% if ${1:condition} %}",
      "  $0",
      "{% endif %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig macro": {
    "prefix": "twig-macro",
    "body": [
      "{% macro ${1:name}(${2:args}) %}",
      "  $0",
      "{% endmacro %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig sandbox": {
    "prefix": "twig-sandbox",
    "body": [
      "{% sandbox %}",
      "  $0",
      "{% endsandbox %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig set": {
    "prefix": "twig-set",
    "body": [
      "{% set ${1:name} %}",
      "  $0",
      "{% endset %}"
    ],
    "description": "twig-core Twig conditional-block tag"
  },
  "Twig types": {
    "prefix": "twig-types",
    "body": [
      "{% types %}",
      "  $0",
      "{% endtypes %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig verbatim": {
    "prefix": "twig-verbatim",
    "body": [
      "{% verbatim %}",
      "  $0",
      "{% endverbatim %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig with": {
    "prefix": "twig-with",
    "body": [
      "{% with ${1:context} %}",
      "  $0",
      "{% endwith %}"
    ],
    "description": "twig-core Twig block tag"
  },
  "Twig deprecated": {
    "prefix": "twig-deprecated",
    "body": [
      "{% deprecated %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig do": {
    "prefix": "twig-do",
    "body": [
      "{% do ${1:expression} %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig extends": {
    "prefix": "twig-extends",
    "body": [
      "{% extends '${1:base.html.twig}' %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig flush": {
    "prefix": "twig-flush",
    "body": [
      "{% flush %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig from": {
    "prefix": "twig-from",
    "body": [
      "{% from '${1:macros.html.twig}' import ${2:macro} %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig import": {
    "prefix": "twig-import",
    "body": [
      "{% import '${1:macros.html.twig}' as ${2:macros} %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig include": {
    "prefix": "twig-include",
    "body": [
      "{% include '${1:template.html.twig}' %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig use": {
    "prefix": "twig-use",
    "body": [
      "{% use '${1:blocks.html.twig}' %}"
    ],
    "description": "twig-core Twig inline tag"
  },
  "Twig elseif": {
    "prefix": "twig-elseif",
    "body": [
      "{% elseif ${1:condition} %}"
    ],
    "description": "twig-core Twig branch tag"
  },
  "Twig else": {
    "prefix": "twig-else",
    "body": [
      "{% else %}"
    ],
    "description": "twig-core Twig branch tag"
  }
}
