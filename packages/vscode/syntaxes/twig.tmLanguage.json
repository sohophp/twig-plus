{
  "scopeName": "text.html.twigplus",
  "name": "TwigPlus",
  "patterns": [
    {
      "include": "#twig-comment"
    },
    {
      "include": "#twig-output"
    },
    {
      "include": "#twig-tag"
    },
    {
      "include": "#embedded-javascript"
    },
    {
      "include": "text.html.basic"
    }
  ],
  "repository": {
    "embedded-javascript": {
      "begin": "(?i)(<script\\b(?:(?!</?script\\b)[\\s\\S])*?>)",
      "beginCaptures": {
        "1": {
          "name": "meta.tag.script.begin.html"
        }
      },
      "end": "(?i)(</script\\s*>)",
      "endCaptures": {
        "1": {
          "name": "meta.tag.script.end.html"
        }
      },
      "contentName": "meta.embedded.block.javascript",
      "patterns": [
        {
          "include": "#twig-comment"
        },
        {
          "include": "#twig-output"
        },
        {
          "include": "#twig-tag"
        },
        {
          "include": "source.js"
        }
      ]
    },
    "twig-comment": {
      "begin": "\\{#",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.twig"
        }
      },
      "end": "#\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.twig"
        }
      },
      "name": "comment.block.twig"
    },
    "twig-output": {
      "begin": "\\{\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.twig"
        }
      },
      "end": "\\}\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.twig"
        }
      },
      "name": "meta.interpolation.twig"
    },
    "twig-tag": {
      "begin": "\\{%",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.embedded.begin.twig"
        }
      },
      "end": "%\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.embedded.end.twig"
        }
      },
      "name": "meta.tag.twig",
      "patterns": [
        {
          "match": "\\b(apply|autoescape|block|cache|embed|for|guard|if|macro|sandbox|set|types|verbatim|with|deprecated|do|extends|flush|from|import|include|use|elseif|else|endapply|endautoescape|endblock|endcache|endembed|endfor|endguard|endif|endmacro|endsandbox|endset|endtypes|endverbatim|endwith)\\b",
          "name": "keyword.control.twig"
        },
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.twig"
        },
        {
          "match": "'[^']*'|\"[^\"]*\"",
          "name": "string.quoted.twig"
        }
      ]
    }
  }
}
