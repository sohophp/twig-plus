{
  "comments": {
    "blockComment": [
      "{#",
      "#}"
    ]
  },
  "brackets": [
    [
      "{%",
      "%}"
    ],
    [
      "{{",
      "}}"
    ],
    [
      "{#",
      "#}"
    ],
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{%",
      "close": "%}"
    },
    {
      "open": "{{",
      "close": "}}"
    },
    {
      "open": "{#",
      "close": "#}"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    },
    {
      "open": "(",
      "close": ")"
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(<(?!(?:/|(?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\\b))[^>]+>(?!.*</)|\\{%\\s*(apply|autoescape|block|cache|embed|for|guard|if|macro|sandbox|set|verbatim|with)\\b.*%\\}|\\{%\\s*(elseif|else)\\b.*%\\})\\s*$",
    "decreaseIndentPattern": "^\\s*(</[^>]+>|\\{%\\s*(endapply|endautoescape|endblock|endcache|endembed|endfor|endguard|endif|endmacro|endsandbox|endset|endverbatim|endwith)\\b.*%\\}|\\{%\\s*(elseif|else)\\b.*%\\})\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*<(?!(?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\\b)([A-Za-z][\\w:-]*)(?:\\s[^<>]*)?>\\s*$",
      "afterText": "^\\s*</[A-Za-z][\\w:-]*\\s*>\\s*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*\\{%\\s*(apply|autoescape|block|cache|embed|for|guard|if|macro|sandbox|set|verbatim|with)\\b.*%\\}\\s*$",
      "afterText": "^\\s*\\{%\\s*(endapply|endautoescape|endblock|endcache|endembed|endfor|endguard|endif|endmacro|endsandbox|endset|endverbatim|endwith)\\b.*%\\}\\s*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*\\{%\\s*(elseif|else)\\b.*%\\}\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*\\{%\\s*(apply|autoescape|block|cache|embed|for|guard|if|macro|sandbox|set|verbatim|with)\\b.*%\\}\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "(",
      ")"
    ],
    [
      "{%",
      "%}"
    ],
    [
      "{{",
      "}}"
    ],
    [
      "{#",
      "#}"
    ]
  ]
}
