{
  "comments": {
    "blockComment": [
      "{#",
      "#}"
    ]
  },
  "brackets": [
    [
      "{%",
      "%}"
    ],
    [
      "{{",
      "}}"
    ],
    [
      "{#",
      "#}"
    ],
    [
      "{",
      "}"
    ],
    [
      "[",
      "]"
    ],
    [
      "(",
      ")"
    ]
  ],
  "autoClosingPairs": [
    {
      "open": "{%",
      "close": "%}"
    },
    {
      "open": "{{",
      "close": "}}"
    },
    {
      "open": "{#",
      "close": "#}"
    },
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    },
    {
      "open": "(",
      "close": ")"
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(<(?!(?:/|(?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\\b))[^>]+>(?!.*</)|\\{%\\s*(if|for|block|embed|macro|apply|filter|autoescape|with|spaceless|set)\\b.*%\\}|\\{%\\s*(else|elseif|empty)\\b.*%\\})\\s*$",
    "decreaseIndentPattern": "^\\s*(</[^>]+>|\\{%\\s*end(if|for|block|embed|macro|apply|filter|autoescape|with|spaceless|set)\\s*%\\}|\\{%\\s*(else|elseif|empty)\\b.*%\\})\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*<(?!(?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\\b)([A-Za-z][\\w:-]*)(?:\\s[^<>]*)?>\\s*$",
      "afterText": "^\\s*</[A-Za-z][\\w:-]*\\s*>\\s*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*\\{%\\s*(if|for|block|embed|macro|apply|filter|autoescape|with|spaceless|set)\\b.*%\\}\\s*$",
      "afterText": "^\\s*\\{%\\s*end(if|for|block|embed|macro|apply|filter|autoescape|with|spaceless|set)\\s*%\\}\\s*$",
      "action": {
        "indent": "indentOutdent"
      }
    },
    {
      "beforeText": "^\\s*\\{%\\s*(else|elseif|empty)\\b.*%\\}\\s*$",
      "action": {
        "indent": "indent"
      }
    },
    {
      "beforeText": "^\\s*\\{%\\s*(if|for|block|embed|macro|apply|filter|autoescape|with|spaceless|set)\\b.*%\\}\\s*$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "(",
      ")"
    ],
    [
      "{%",
      "%}"
    ],
    [
      "{{",
      "}}"
    ],
    [
      "{#",
      "#}"
    ]
  ]
}
