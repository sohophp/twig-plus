{
  "schemaVersion": 1,
  "cases": [
    { "id": "tag-apply", "feature": "tag:apply", "valid": true, "source": "{% apply upper %}value{% endapply %}" },
    { "id": "tag-autoescape", "feature": "tag:autoescape", "valid": true, "source": "{% autoescape 'html' %}{{ value }}{% endautoescape %}" },
    { "id": "tag-block", "feature": "tag:block", "valid": true, "source": "{% block content %}value{% endblock %}" },
    { "id": "tag-cache", "feature": "tag:cache", "valid": true, "source": "{% cache 'key' ttl(300) tags(['docs']) %}value{% endcache %}" },
    { "id": "tag-deprecated", "feature": "tag:deprecated", "valid": true, "source": "{% deprecated 'Use the new template.' %}" },
    { "id": "tag-do", "feature": "tag:do", "valid": true, "source": "{% do 1 + 2 %}" },
    { "id": "tag-embed", "feature": "tag:embed", "valid": true, "source": "{% embed 'layout.twig' %}{% block content %}value{% endblock %}{% endembed %}" },
    { "id": "tag-extends", "feature": "tag:extends", "valid": true, "source": "{% extends 'layout.twig' %}{% block content %}value{% endblock %}" },
    { "id": "tag-flush", "feature": "tag:flush", "valid": true, "source": "{% flush %}" },
    { "id": "tag-for", "feature": "tag:for", "valid": true, "source": "{% for key, value in values %}{{ key }}={{ value }}{% else %}empty{% endfor %}" },
    { "id": "tag-from", "feature": "tag:from", "valid": true, "source": "{% from 'macros.twig' import field as input %}{{ input('name') }}" },
    { "id": "tag-guard", "feature": "tag:guard", "valid": true, "source": "{% guard function range %}{{ range(1, 2) }}{% else %}fallback{% endguard %}" },
    { "id": "tag-if", "feature": "tag:if", "valid": true, "source": "{% if user is defined %}{{ user.name }}{% elseif fallback %}fallback{% else %}none{% endif %}" },
    { "id": "tag-import", "feature": "tag:import", "valid": true, "source": "{% import 'macros.twig' as forms %}{{ forms.field('name') }}" },
    { "id": "tag-include", "feature": "tag:include", "valid": true, "source": "{% include 'partial.twig' with {name: 'Twig'} only %}" },
    { "id": "tag-macro", "feature": "tag:macro", "valid": true, "source": "{% macro field(name, type = 'text') %}{{ name }}{% endmacro %}" },
    { "id": "tag-sandbox", "feature": "tag:sandbox", "valid": true, "source": "{% sandbox %}{% include 'partial.twig' %}{% endsandbox %}" },
    { "id": "tag-set", "feature": "tag:set", "valid": true, "source": "{% set first, second = values[0], values[1] %}{% set captured %}value{% endset %}" },
    { "id": "tag-types", "feature": "tag:types", "valid": true, "source": "{% types {user: 'App\\Model\\User', title?: 'string'} %}" },
    { "id": "tag-use", "feature": "tag:use", "valid": true, "source": "{% use 'blocks.twig' with content as imported_content %}" },
    { "id": "tag-verbatim", "feature": "tag:verbatim", "valid": true, "source": "{% verbatim %}{{ untouched }}{% endverbatim %}" },
    { "id": "tag-with", "feature": "tag:with", "valid": true, "source": "{% with {name: 'Twig'} only %}{{ name }}{% endwith %}" },
    { "id": "expr-defined-flow", "feature": "test:defined", "valid": true, "source": "{% if user is defined and user.active %}{{ user.name }}{% endif %}" },
    { "id": "expr-named-arguments", "feature": "syntax:named-arguments", "valid": true, "source": "{{ include('partial.twig', variables: {name: 'Twig'}, with_context: false) }}" },
    { "id": "expr-arrow", "feature": "operator:=>", "valid": true, "source": "{{ values|map((value, key) => key ~ value) }}" },
    { "id": "expr-safe-navigation", "feature": "operator:?.", "valid": true, "source": "{{ user?.profile?.name ?? 'anonymous' }}" },
    { "id": "expr-spread", "feature": "operator:...", "valid": true, "source": "{{ [first, ...rest] }}" },
    { "id": "expr-comparisons", "feature": "operator:<=>", "valid": true, "source": "{{ left === right or (left <=> right) == 0 }}" },
    { "id": "expr-containment", "feature": "operator:has-every", "valid": true, "source": "{{ values has every required and values has some optional }}" },
    { "id": "expr-bitwise", "feature": "operator:b-xor", "valid": true, "source": "{{ 1 b-or 2 b-xor 3 b-and 4 }}" },
    { "id": "expr-inline-comment", "feature": "syntax:inline-comment", "valid": true, "source": "{{ value # explanation\n}}" },
    { "id": "invalid-types-closing", "feature": "recovery:types", "valid": false, "source": "{% types {user: 'User'} %}{% endtypes %}" },
    { "id": "invalid-for-empty", "feature": "recovery:for-empty", "valid": false, "source": "{% for item in items %}{{ item }}{% empty %}none{% endfor %}" },
    { "id": "invalid-incomplete-if", "feature": "recovery:incomplete", "valid": false, "source": "{% if user is defined %}{{ user.name }}" }
  ]
}
